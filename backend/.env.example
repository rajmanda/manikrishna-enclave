# Copy to .env for local development. In staging/production these come from
# Google Secret Manager — never commit real values.

ENVIRONMENT=dev
# MongoDB Atlas connection string (same cluster for dev and prod;
# use DB_NAME to keep environments separate)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=communityhub_dev

# OAuth client ID from Google Cloud Console (Web application type)
GOOGLE_CLIENT_ID=

JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_MINUTES=1440

# Enables /auth/dev-login. MUST be false outside local dev.
DEV_MODE=true

# Seed Mani Krishna Enclave on startup if the database is empty.
SEED_ON_START=true

CORS_ORIGINS=http://localhost:3000,https://community.rajmanda.com
