# Base URL of the FastAPI backend. In dev, the relative path goes through the
# Next dev server, which proxies /api/v1/* to localhost:8000 (see rewrites in
# next.config.ts) — same-origin, so it also works from a phone via ngrok.
NEXT_PUBLIC_API_URL=/api/v1

# Google OAuth web client ID — the Google sign-in button renders once set.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Set to "false" to hide the dev quick-login and account switcher (production).
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true
